#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["requests>=2.31"]
# ///
"""sift-tool — sift's data-tool implementation. The user-facing CLI is
`sift`, which forwards research and vault subcommands here. The actual
implementation lives in the `tool` package under <pkg>/lib/; this file
is a uv inline-script shim that puts that package on sys.path and
delegates to its main()."""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

from tool.cli import main  # noqa: E402

sys.exit(main())
