#!/usr/bin/env bash
# sift — investigative research agent that runs entirely on your Mac.
#
# Talks to an OCCRP Aleph instance through Mario Zechner's `pi` agent
# harness, with a local Qwen3.6 35B A3B served by llama.cpp. Credentials
# and research products live in an encrypted sparseimage vault at
# ~/.sift/.vault.sparseimage; nothing leaves your machine except the
# Aleph API queries themselves.
#
#   sift init                       # one-time setup (vault, creds, model)
#   sift "investigate Acme Corp..." # headless one-shot
#   sift                            # interactive REPL
#   sift --debug "..."              # headless + raw JSON event stream
#
# Each headless invocation gets its own session directory inside the
# vault (timestamp + slug), so runs don't stomp on each other.

set -euo pipefail

SIFT_HOME="${SIFT_HOME:-$HOME/.sift}"
SIFT_BACKEND="${SIFT_BACKEND:-llamacpp}"
SIFT_PORT="${SIFT_PORT:-1234}"

# Default model — Qwen3.6 35B A3B (MoE; ~3B active), unsloth UD-Q2_K_XL
# quant. ~12.3 GB on disk, comfortable on a 24 GB Mac alongside a 32k
# context window.
DEFAULT_MODEL_REPO="unsloth/Qwen3.6-35B-A3B-GGUF"
DEFAULT_MODEL_FILE="Qwen3.6-35B-A3B-UD-Q2_K_XL.gguf"
DEFAULT_MODEL_NAME="qwen3.6-35b-a3b"

# Resolve where the package lives (Homebrew installs to libexec; binary is
# symlinked into bin/). realpath -> .../libexec/bin/sift -> .../libexec.
SIFT_PACKAGE="$(cd "$(dirname "$(/usr/bin/python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0")")/.." && pwd)"
SKILL="$SIFT_PACKAGE/share/aleph"
AGENTS_MD="$SIFT_PACKAGE/share/AGENTS.md"

# Every sift subcommand that talks to aleph (search, read, vault, …) needs
# this so the bundled CLI finds the vault at $SIFT_HOME/.vault.sparseimage
# instead of walking up from the caller's cwd.
export ALEPH_PROJECT_DIR="$SIFT_HOME"

log() { printf '%-9s %s\n' "[$1]" "$2"; }
die() { log error "$1"; exit 1; }

require() {
  command -v "$1" >/dev/null 2>&1 \
    || die "missing dependency: $1${2:+  (install: $2)}"
}

ensure_initialized() {
  [[ -f "$SIFT_HOME/.initialized" ]] \
    || die "sift isn't set up yet — run 'sift init' first"
}

# ---------------------------------------------------------------------------
# Backend (local LLM server)
# ---------------------------------------------------------------------------

backend_health() {
  curl -sf "http://127.0.0.1:$SIFT_PORT/v1/models" >/dev/null 2>&1
}

backend_start_llamacpp() {
  if backend_health; then
    log server "llama-server already up on :$SIFT_PORT"
    return
  fi
  local model_path="$SIFT_HOME/models/$DEFAULT_MODEL_FILE"
  [[ -f "$model_path" ]] || die "model not found at $model_path — run 'sift init'"
  log server "starting llama-server on :$SIFT_PORT (logs: $SIFT_HOME/llama-server.log)"
  nohup llama-server \
    --model "$model_path" \
    --host 127.0.0.1 \
    --port "$SIFT_PORT" \
    --jinja \
    --no-webui \
    --ctx-size 32768 \
    --reasoning-budget 16384 \
    --alias "$DEFAULT_MODEL_NAME" \
    >"$SIFT_HOME/llama-server.log" 2>&1 &
  echo $! >"$SIFT_HOME/llama-server.pid"
  for _ in $(seq 1 120); do
    sleep 1
    backend_health && { log server "ready"; return; }
  done
  die "llama-server didn't become ready in 120s — check $SIFT_HOME/llama-server.log"
}

backend_start_lmstudio() {
  require lms "https://lmstudio.ai/"
  local server_msg port
  server_msg=$(lms server start 2>&1 || true)
  port=$(printf '%s' "$server_msg" | grep -oE 'port [0-9]+' | head -n1 | awk '{print $2}')
  if [[ -n "$port" ]]; then
    SIFT_PORT="$port"
    log server "running on :$port"
  else
    log server "$server_msg"
  fi
}

backend_start() {
  case "$SIFT_BACKEND" in
    llamacpp) backend_start_llamacpp ;;
    lmstudio) backend_start_lmstudio ;;
    *) die "unknown SIFT_BACKEND: $SIFT_BACKEND (expected llamacpp or lmstudio)" ;;
  esac
}

# Write pi's provider config so it talks to whichever backend is running.
# Idempotent — overwritten every run so the port stays in sync.
configure_pi() {
  mkdir -p "$SIFT_HOME/pi"
  cat >"$SIFT_HOME/pi/models.json" <<JSON
{
  "providers": {
    "sift": {
      "baseUrl": "http://127.0.0.1:$SIFT_PORT/v1",
      "api": "openai-completions",
      "apiKey": "sift-local",
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": false
      },
      "models": [
        {"id": "$DEFAULT_MODEL_NAME", "name": "Qwen3.6 35B A3B"}
      ]
    }
  }
}
JSON
  cat >"$SIFT_HOME/pi/settings.json" <<JSON
{
  "defaultProvider": "sift",
  "defaultModel": "$DEFAULT_MODEL_NAME"
}
JSON
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

cmd_init() {
  log init "checking dependencies"
  require uv     "brew install uv"
  require pi     "npm install -g @mariozechner/pi"
  require swiftc "xcode-select --install"
  case "$SIFT_BACKEND" in
    llamacpp) require llama-server "brew install llama.cpp" ;;
    lmstudio) require lms          "https://lmstudio.ai/" ;;
  esac

  mkdir -p "$SIFT_HOME"

  if [[ ! -f "$SIFT_HOME/.vault.sparseimage" ]]; then
    log init "creating encrypted vault at $SIFT_HOME/.vault.sparseimage"
    "$SKILL/aleph" vault init >/dev/null
  else
    log init "vault already exists"
  fi
  "$SKILL/aleph" vault unlock >/dev/null

  log init "configuring Aleph credentials"
  printf 'Aleph URL [https://aleph.occrp.org]: '
  read -r aleph_url
  aleph_url="${aleph_url:-https://aleph.occrp.org}"
  printf 'Aleph API key (input hidden): '
  if [[ -t 0 ]]; then
    stty -echo
    read -r aleph_key
    stty echo
    printf '\n'
  else
    # Piped stdin (e.g. a colleague scripting setup) — no echo control needed.
    read -r aleph_key
  fi
  [[ -n "$aleph_key" ]] || die "API key required"
  "$SKILL/aleph" vault set ALEPH_URL     "$aleph_url" >/dev/null
  "$SKILL/aleph" vault set ALEPH_API_KEY "$aleph_key" >/dev/null

  if [[ "$SIFT_BACKEND" == "llamacpp" ]]; then
    mkdir -p "$SIFT_HOME/models"
    local model_path="$SIFT_HOME/models/$DEFAULT_MODEL_FILE"
    if [[ ! -f "$model_path" ]]; then
      log init "downloading model (~12GB) — go get a coffee"
      # Resolve the HF redirect to the signed CDN URL first, then download
      # in one shot. Without this, curl's --progress-bar shows a misleading
      # 100% bar for the small redirect document before the real download
      # of the 12GB file even starts.
      local resolved_url
      resolved_url=$(curl -fsLI \
        "https://huggingface.co/$DEFAULT_MODEL_REPO/resolve/main/$DEFAULT_MODEL_FILE" \
        -o /dev/null -w '%{url_effective}')
      [[ -n "$resolved_url" ]] || die "couldn't resolve model URL on huggingface.co"
      curl --fail --progress-bar --retry 5 --retry-all-errors \
        -o "$model_path.partial" "$resolved_url"
      mv "$model_path.partial" "$model_path"
    else
      log init "model already downloaded"
    fi
  fi

  touch "$SIFT_HOME/.initialized"
  log init "done — try: sift \"investigate <subject>\""
}

cmd_auto() {
  ensure_initialized
  backend_start
  configure_pi

  local prompt=""
  local debug=0
  local pi_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --prompt)   prompt="${2:?--prompt requires a value}"; shift 2 ;;
      --prompt=*) prompt="${1#--prompt=}"; shift ;;
      --debug)    debug=1; shift ;;
      -*)         pi_args+=("$1"); shift ;;
      *)
        if [[ -z "$prompt" ]]; then prompt="$1"; else pi_args+=("$1"); fi
        shift ;;
    esac
  done

  export PI_CODING_AGENT_DIR="$SIFT_HOME/pi"

  if [[ -z "$prompt" ]]; then
    # Interactive REPL — drop straight into pi.
    exec "$SKILL/aleph" vault exec pi \
      --append-system-prompt "$AGENTS_MD" \
      --skill "$SKILL"
  fi

  local slug
  slug=$(printf '%s' "$prompt" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -c 'a-z0-9' '-' \
    | sed -E 's/-+/-/g; s/^-//; s/-$//' \
    | cut -c1-40)
  export ALEPH_SESSION="$(date +%Y%m%d-%H%M%S)${slug:+-$slug}"

  set +e
  "$SKILL/aleph" vault exec pi \
    --append-system-prompt "$AGENTS_MD" \
    --skill "$SKILL" \
    -p --mode json "$prompt" ${pi_args[@]+"${pi_args[@]}"} \
    | SIFT_DEBUG="$debug" python3 -u "$SIFT_PACKAGE/bin/sift-log.py"
  local rc=${PIPESTATUS[0]}
  set -e
  exit "$rc"
}

usage() {
  cat <<'EOF'
sift — investigative research agent that runs entirely on your Mac.

Setup:
  sift init                              one-time: vault, creds, model

Agent (headless or REPL):
  sift auto "investigate Acme Corp..."   headless one-shot
  sift auto                              interactive REPL
  sift auto --debug "..."                + raw JSON event stream

Aleph tools (also available to the agent):
  sift search query="..." [type=...] [collection=...]
  sift read   alias=r5
  sift expand alias=r5
  sift browse | tree | similar | hubs | sources    (see 'sift <cmd> --help')
  sift vault status | unlock | lock | set | get | list

Environment:
  SIFT_HOME     where the vault, model, and pi config live (default ~/.sift)
  SIFT_BACKEND  llamacpp (default) or lmstudio
  SIFT_PORT     local LLM server port (default 1234)
EOF
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

case "${1:-}" in
  ""|--help|-h)
    usage; exit 0 ;;
  init)
    shift; cmd_init "$@" ;;
  auto)
    shift; cmd_auto "$@" ;;
  search|read|expand|browse|tree|similar|hubs|sources|vault)
    # Forward to the bundled aleph CLI. ALEPH_PROJECT_DIR is exported at
    # the top of this script, so the vault is found regardless of cwd.
    exec "$SKILL/aleph" "$@" ;;
  *)
    die "unknown command: $1 (try 'sift --help')" ;;
esac
